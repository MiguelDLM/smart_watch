<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jieli Watch Dial Sender"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scan &amp; Connect" />

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="Status: Disconnected" />

    <Button
        android:id="@+id/btnSelectFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Dial File (.bin)"
        android:enabled="false"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnCreateDial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create New Dial"
        android:layout_marginTop="8dp"
        android:backgroundTint="#009688"/>
    
    <Button
        android:id="@+id/btnCopyLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Copy Logs to Clipboard"
        android:layout_marginTop="8dp"/>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:max="100"
        android:progress="0" />
    
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:background="#EEEEEE"
        android:fillViewport="true">

        <TextView
            android:id="@+id/txtLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:scrollbars="vertical"
            android:textIsSelectable="true"
            android:text="Log:\n"
            android:textSize="12sp"
            android:typeface="monospace" />
    </ScrollView>

    <TextView
        android:id="@+id/txtVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:padding="4dp"
        android:text="v1.3 - Scroll + LE Length"
        android:textColor="#888888"
        android:textSize="10sp" />

</LinearLayout>
