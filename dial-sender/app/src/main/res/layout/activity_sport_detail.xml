<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1116"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row with Back button and Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:contentDescription="Atrás"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/txtSportTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Detalle de Entrenamiento"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_share"
                android:contentDescription="Compartir Ruta"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Stats Card (CoFit/STF Dark premium style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/txtSessionDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01 de Enero de 2026, 08:30"
                android:textColor="#9AA4B2"
                android:textSize="13sp"
                android:layout_marginBottom="16dp"/>

            <!-- Main Stats Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="3"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false"
                android:useDefaultMargins="true">

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Duración"
                        android:textColor="#9AA4B2"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/txtDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textColor="#22D3EE"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Distance -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distancia"
                        android:textColor="#9AA4B2"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/txtDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 km"
                        android:textColor="#22D3EE"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Calories -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calorías"
                        android:textColor="#9AA4B2"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/txtCalories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 kcal"
                        android:textColor="#EF4444"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Ritmo/Pace -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ritmo Medio"
                        android:textColor="#9AA4B2"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/txtPace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--'--"
                        android:textColor="#22D3EE"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Heart Rate Avg -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Frec. Cardíaca Med."
                        android:textColor="#9AA4B2"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/txtAvgHr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- ppm"
                        android:textColor="#EF4444"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Elevation gain -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Elevación Acum."
                        android:textColor="#9AA4B2"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/txtElevation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- m"
                        android:textColor="#F59E0B"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </GridLayout>
        </LinearLayout>

        <!-- Map Section Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ruta de Entrenamiento"
            android:textColor="#9AA4B2"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp" />

        <!-- WebView Map (Rounded corners container) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="18dp"
            android:backgroundTint="#1A2027">

            <WebView
                android:id="@+id/mapWebView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </androidx.cardview.widget.CardView>

        <!-- Charts Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gráficos de Rendimiento"
            android:textColor="#9AA4B2"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Heart Rate Chart Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ritmo Cardíaco (ppm)"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>
            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartHeartRate"
                android:layout_width="match_parent"
                android:layout_height="180dp" />
        </LinearLayout>

        <!-- Elevation Chart Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elevación (m)"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>
            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartElevation"
                android:layout_width="match_parent"
                android:layout_height="180dp" />
        </LinearLayout>

        <!-- Speed Chart Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Velocidad (km/h)"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>
            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartSpeed"
                android:layout_width="match_parent"
                android:layout_height="180dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
