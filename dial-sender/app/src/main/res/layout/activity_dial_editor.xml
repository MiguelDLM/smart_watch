<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBackEditor"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="12dp"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dial_designer"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnUpload"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            style="@style/ButtonSuccess"
            android:text="@string/compile"
            android:textSize="13sp"
            android:paddingHorizontal="16dp"/>
    </LinearLayout>

    <!-- Main Content: Preview + Layer Panel side by side on landscape, stacked on portrait -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Preview Area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#050810">

            <FrameLayout
                android:id="@+id/previewContainer"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                android:background="@color/bg_card"/>

            <View
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_mask"
                android:clickable="false"/>
        </FrameLayout>

        <!-- Layer Panel (Photoshop-style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/bg_surface"
            android:padding="0dp">

            <!-- Layer Panel Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@color/bg_elevated"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/layers_title"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/txtLayerCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/btnAddElement"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="＋"
                    android:textColor="@color/accent_primary"
                    android:textSize="22sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </LinearLayout>

            <!-- Layer List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/layerRecycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="4dp"/>

            <!-- Bottom Controls for selected layer -->
            <LinearLayout
                android:id="@+id/selectedLayerControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_elevated"
                android:padding="10dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtSelectedLayer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/accent_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <!-- Scale -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="@string/scale"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"/>
                    <SeekBar
                        android:id="@+id/seekScale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="200"
                        android:progress="100"
                        android:progressTint="@color/accent_primary"
                        android:thumbTint="@color/accent_primary"/>
                </LinearLayout>

                <!-- Rotation -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="@string/rotation"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"/>
                    <SeekBar
                        android:id="@+id/seekRotation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="360"
                        android:progress="0"
                        android:progressTint="@color/accent_purple"
                        android:thumbTint="@color/accent_purple"/>
                </LinearLayout>

                <!-- Move buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <Button
                        android:id="@+id/btnMoveUp"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="34dp"
                        style="@style/ButtonSecondary"
                        android:text="▲"
                        android:textSize="14sp"
                        android:layout_marginEnd="4dp"/>
                    <Button
                        android:id="@+id/btnMoveDown"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="34dp"
                        style="@style/ButtonSecondary"
                        android:text="▼"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>