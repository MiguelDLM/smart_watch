<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="#1F1F1F"
        android:gravity="center_vertical">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dial Designer"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnUpload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMPILE &amp; UPLOAD"
            android:backgroundTint="#6200EE"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Preview Area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.2"
            android:background="#000000">

            <FrameLayout
                android:id="@+id/previewContainer"
                android:layout_width="320dp"
                android:layout_height="320dp"
                android:layout_gravity="center"
                android:background="#222222">
                <!-- Layers added dynamically here -->
            </FrameLayout>
            
            <!-- Mask -->
            <View
                android:layout_width="320dp"
                android:layout_height="320dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_mask"
                android:clickable="false"/>
        </FrameLayout>

        <!-- Controls Area -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Actions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    
                    <Button
                        android:id="@+id/btnAddElement"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Add Layer"
                        android:layout_marginEnd="8dp"/>
                        
                    <Button
                        android:id="@+id/btnRemoveLayer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remove"
                        android:backgroundTint="#B00020"/>
                </LinearLayout>

                <!-- Selected Layer Controls -->
                <TextView
                    android:id="@+id/txtSelectedLayer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No layer selected"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Scale"
                    android:textColor="#AAAAAA"/>
                <SeekBar
                    android:id="@+id/seekScale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="100"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rotation"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="8dp"/>
                <SeekBar
                    android:id="@+id/seekRotation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="360"
                    android:progress="0"/>
                    
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Layer Order"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="16dp"/>
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/btnMoveUp"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Move Up"/>
                    <Button
                        android:id="@+id/btnMoveDown"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Move Down"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>