<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Live Preview -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="#0A0A12"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/imgFontPreview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:scaleType="fitCenter"/>
        </FrameLayout>

        <!-- Font Selector -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/font_label"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerFont"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@color/bg_card"
            android:padding="8dp"
            android:layout_marginBottom="12dp"/>

        <!-- Digit Size -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/digit_size"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekDigitSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="16"
            android:max="120"
            android:progress="48"
            android:progressTint="@color/accent_primary"
            android:thumbTint="@color/accent_primary"
            android:layout_marginBottom="12dp"/>

        <!-- Color -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/font_color"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:id="@+id/colorPalette"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"/>

        <!-- Glow / Shadow -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/glow_label"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekGlow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="20"
            android:progress="0"
            android:progressTint="@color/accent_purple"
            android:thumbTint="@color/accent_purple"
            android:layout_marginBottom="12dp"/>

        <!-- Border / Outline -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/border_label"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekBorder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="0"
            android:progressTint="@color/accent_primary"
            android:thumbTint="@color/accent_primary"
            android:layout_marginBottom="6dp"/>

        <!-- Border Color -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/border_color"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:id="@+id/borderColorPalette"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"/>

        <!-- Spacing -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/spacing_label"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekSpacing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="40"
            android:progress="0"
            android:progressTint="@color/accent_cyan"
            android:thumbTint="@color/accent_cyan"
            android:layout_marginBottom="12dp"/>

    </LinearLayout>
</ScrollView>
